<Window x:Class="EOLTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:EOLTest"
        xmlns:vm="clr-namespace:EOLTest.ViewModels"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="EOL测试上位机" Height="600" Width="950"
        WindowState="Maximized"          
        Background="#ECF0F1" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FunctionItemPassedStyle" TargetType="Border">
            <Setter Property="Background" Value="#E8F8F5"/>
            <Setter Property="BorderBrush" Value="#D5D8DC"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FunctionItemFailedStyle" TargetType="Border">
            <Setter Property="Background" Value="#FDEDEC"/>
            <Setter Property="BorderBrush" Value="#D5D8DC"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FunctionItemPendingStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D5D8DC"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FunctionItemRunningStyle" TargetType="Border">
            <Setter Property="Background" Value="#EBF5FB"/>
            <Setter Property="BorderBrush" Value="#3498DB"/>
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel Margin="6">

        <!-- ==================== 1. 顶部工具栏 ==================== -->
        <Border DockPanel.Dock="Top" 
                Background="White" 
                CornerRadius="4" 
                Margin="0,0,0,6"
                Padding="8,6"
                BorderBrush="#D5D8DC" 
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Button Content="📌 工位" 
                        Width="75" Height="30" 
                        Margin="0,0,8,0"
                        Background="#2C3E50" 
                        Foreground="White" 
                        BorderThickness="0"
                        FontSize="12"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="⚙️ 设置" 
                        Width="75" Height="30"
                        Margin="0,0,8,0"
                        Background="White" 
                        BorderBrush="#D5D8DC" 
                        BorderThickness="1"
                        FontSize="12"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="📊 统计" 
                        Width="75" Height="30"
                        Background="White" 
                        BorderBrush="#D5D8DC" 
                        BorderThickness="1"
                        FontSize="12"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- ==================== 2. 条码输入区 + 校验提示区 ==================== -->
        <Border DockPanel.Dock="Top" 
                Background="White" 
                CornerRadius="4" 
                Margin="0,0,0,6"
                Padding="12,10"
                BorderBrush="#D5D8DC" 
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 第一行：条码输入 -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#2C3E50" CornerRadius="3" Padding="10,5" Margin="0,0,12,0">
                        <TextBlock Text="VIN码" Foreground="White" FontWeight="Bold" FontSize="20"/>
                    </Border>
                    <TextBox x:Name="VinTextBox"
                             Grid.Column="1" 
                             Height="38" 
                             FontSize="24" 
                             FontWeight="SemiBold"
                             FontFamily="Consolas"
                             TextAlignment="Center" 
                             VerticalContentAlignment="Center"
                             BorderBrush="#D5D8DC"
                             BorderThickness="1"
                             Background="#F8F9FA"
                             CharacterCasing="Upper"
                             Text="{Binding CurrentVehicle.Vin, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,12,0">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="TextChanged">
                                <i:InvokeCommandAction Command="{Binding CheckVinIsTrueCommand}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </TextBox>

                    <Border Grid.Column="2" Background="#2C3E50" CornerRadius="3" Padding="10,5" Margin="0,0,12,0">
                        <TextBlock Text="VSN码" Foreground="White" FontWeight="Bold" FontSize="20"/>
                    </Border>
                    <TextBox x:Name="VsnTextBox"
                             Grid.Column="3" 
                             Height="38" 
                             FontSize="24" 
                             FontWeight="SemiBold"
                             FontFamily="Consolas"
                             TextAlignment="Center" 
                             VerticalContentAlignment="Center"
                             BorderBrush="#D5D8DC"
                             BorderThickness="1"
                             Background="#F8F9FA"
                             Text="{Binding CurrentVehicle.Vsn, UpdateSourceTrigger=PropertyChanged}"
                             CharacterCasing="Upper">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="TextChanged">
                                <i:InvokeCommandAction Command="{Binding CheckVsnIsTrueCommand}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </TextBox>
                </Grid>

                <!-- 第二行：校验提示 + 车型/发动机信息 -->
                <Border Grid.Row="1" 
                        Background="#F8F9FA" 
                        CornerRadius="3" 
                        Padding="12,6"
                        BorderBrush="#D5D8DC" 
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左侧：校验结果显示（成功/失败） -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" MinWidth="200">
                            <!-- 成功状态 -->
                            <StackPanel x:Name="VinSuccessPanel" Orientation="Horizontal" Visibility="Collapsed">
                                <TextBlock Text="✅" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock x:Name="VinSuccessText" 
                                           Text="VIN校验通过" 
                                           FontSize="14" 
                                           FontWeight="Bold" 
                                           Foreground="#27AE60"/>
                            </StackPanel>

                            <!-- 失败状态 -->
                            <StackPanel x:Name="VinFailPanel" Orientation="Horizontal" Visibility="Collapsed">
                                <TextBlock Text="❌" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock x:Name="VinFailText" 
                                           Text="VIN校验失败" 
                                           FontSize="14" 
                                           FontWeight="Bold" 
                                           Foreground="#E74C3C"/>
                            </StackPanel>

                            <!-- 默认状态（未输入） -->
                            <StackPanel x:Name="VinDefaultPanel" Orientation="Horizontal">
                                <TextBlock Text="⏸️" FontSize="14" Margin="0,0,8,0" Opacity="0.4"/>
                                <TextBlock Text="等待输入VIN/VSN..." 
                                           FontSize="13" 
                                           Foreground="#95A5A6"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 中间：弹性空白 -->
                        <Border Grid.Column="1"/>

                        <!-- 右侧：车型/发动机信息（校验通过后显示） -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="🚗 车型：" FontSize="13" FontWeight="SemiBold" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="CarModelText"
                                       Text="{Binding CurrentVehicle.CxName}"
                                       FontSize="13" 
                                       FontWeight="Bold" 
                                       Foreground="#2C3E50"
                                       Margin="0,0,25,0"/>

                            <TextBlock Text="⚙️ 发动机：" FontSize="13" FontWeight="SemiBold" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="EngineText"
                                       Text="--" 
                                       FontSize="13" 
                                       FontWeight="Bold" 
                                       Foreground="#2C3E50"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ==================== 3. 底部状态栏 ==================== -->
        <Border DockPanel.Dock="Bottom" 
        Background="#2C3E50" 
        CornerRadius="3"
        Margin="0,6,0,0"
        Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- ★★★ 左侧：设备连接状态（改为数据绑定） ★★★ -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- 圆形指示灯：根据 IsVciConnected 切换颜色 -->
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <!-- 默认灰色（未知状态） -->
                                <Setter Property="Fill" Value="Gray"/>
                                <Style.Triggers>
                                    <!-- 已连接 → 绿色 -->
                                    <DataTrigger Binding="{Binding IsVciConnected}" Value="True">
                                        <Setter Property="Fill" Value="#2ECC71"/>
                                    </DataTrigger>
                                    <!-- 未连接/失败 → 红色 -->
                                    <DataTrigger Binding="{Binding IsVciConnected}" Value="False">
                                        <Setter Property="Fill" Value="#E74C3C"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <!-- 状态文字：自动显示"正在连接..."/"设备已连接"/"设备连接失败"等 -->
                    <TextBlock Text="{Binding ConnectionStatusText}" 
                       Foreground="#BDC3C7" FontSize="11"/>
                    <TextBlock Text=" | PLC已连接" 
                       Foreground="#BDC3C7" FontSize="11" Margin="12,0,0,0"/>
                </StackPanel>
                <!-- 中间和右侧不变 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="当前工位: EOL测试工位 #01" Foreground="#BDC3C7" FontSize="11"/>
                    <TextBlock Text=" | 操作员: Admin" Foreground="#BDC3C7" FontSize="11" Margin="15,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="📊 v2.1.3" Foreground="#95A5A6" FontSize="11" Margin="0,0,12,0"/>
                    <TextBlock x:Name="DateTimeTextBlock"
                       Text="2026-04-21 14:30:25" 
                       Foreground="#95A5A6" 
                       FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== 4. 中间核心区 ==================== -->
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧：功能列表 ===== -->
            <Border Grid.Column="0" 
                    Background="White" 
                    CornerRadius="4" 
                    BorderBrush="#D5D8DC" 
                    BorderThickness="1"
                    Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" 
                            Background="#2C3E50"
                            CornerRadius="4,4,0,0"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 检测功能" 
                                       Foreground="White" 
                                       FontWeight="Bold" 
                                       FontSize="13"/>
                            <TextBlock x:Name="FunctionCountText"
                                       Text=" (4项)" 
                                       Foreground="#95A5A6" 
                                       FontSize="11" 
                                       Margin="5,1,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- 功能1：已通过 -->
                            <Border Style="{StaticResource FunctionItemPassedStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#27AE60" CornerRadius="1" Margin="-11,-9,-7,-9"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="✅" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="条码读取验证" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                        <TextBlock Text="通过" Foreground="#27AE60" FontSize="11" FontWeight="SemiBold" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 功能2：失败 -->
                            <Border Style="{StaticResource FunctionItemFailedStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#E74C3C" CornerRadius="1" Margin="-11,-9,-7,-9"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="❌" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="相机取图检测" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                        <TextBlock Text="失败" Foreground="#E74C3C" FontSize="11" FontWeight="SemiBold" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 功能3：执行中 -->
                            <Border Style="{StaticResource FunctionItemRunningStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#3498DB" CornerRadius="1" Margin="-13,-9,-7,-9"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="⏳" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="尺寸测量计算" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                        <Border Background="#3498DB" CornerRadius="8" Padding="6,2" Margin="12,0,0,0">
                                            <TextBlock Text="执行中" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 功能4：待执行 -->
                            <Border Style="{StaticResource FunctionItemPendingStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏸️" FontSize="14" Margin="0,0,8,0" Opacity="0.4"/>
                                    <TextBlock Text="数据上传服务器" FontSize="13" Foreground="#95A5A6"/>
                                    <TextBlock Text="待执行" Foreground="#95A5A6" FontSize="11" Margin="12,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ===== 右侧：功能标题 + 标签页 ===== -->
            <Border Grid.Column="2" 
                    Background="White" 
                    CornerRadius="4" 
                    BorderBrush="#D5D8DC" 
                    BorderThickness="1"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 当前功能标题 -->
                    <Border Grid.Row="0" 
                            BorderBrush="#D5D8DC" 
                            BorderThickness="0,0,0,1"
                            Padding="0,0,0,10"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock x:Name="CurrentFunctionTitle"
                                           Text="等待检测..." 
                                           FontSize="18" 
                                           FontWeight="Bold" 
                                           Foreground="#2C3E50"/>
                                <Border x:Name="StepIndicator"
                                        Background="#EBF5FB" 
                                        CornerRadius="3" 
                                        Padding="6,3" 
                                        Margin="12,0,0,0"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="StepText"
                                               Text="步骤 0/4" 
                                               Foreground="#3498DB" 
                                               FontSize="11" 
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <Border Grid.Column="2" 
                                    Background="#FEF5E7" 
                                    CornerRadius="12" 
                                    Padding="12,5"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏳ 正在执行：" Foreground="#E67E22" FontSize="12"/>
                                    <TextBlock x:Name="CurrentStepText"
                                               Text="等待中" 
                                               Foreground="#E67E22" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 标签页：日志 + 数据流 -->
                    <TabControl Grid.Row="1" 
                                Background="White" 
                                BorderBrush="#D5D8DC"
                                SelectedIndex="{Binding SelectedTabIndex}"
                                >
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="Background" Value="#F8F9FA"/>
                                <Setter Property="BorderBrush" Value="#D5D8DC"/>
                                <Setter Property="BorderThickness" Value="1,1,1,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3,3,0,0"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter ContentSource="Header" 
                                                                  HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                    <Setter Property="BorderThickness" Value="1,2,1,1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- ==================== 运行日志 Tab ==================== -->
                        <TabItem Header="📝 运行日志">
                            <Border Background="#1A1A1A" CornerRadius="0,0,3,3">
                                <!-- 
            RichTextBox 用于显示彩色日志
            x:Name 保留，因为需要在代码后置中传给 LogShowService
        -->
                                <RichTextBox x:Name="LogRichTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Margin="4"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Foreground="#DDDDDD">
                                    <!-- 初始空文档 -->
                                    <FlowDocument PageWidth="2000" />
                                </RichTextBox>
                            </Border>
                        </TabItem>

                        <!-- 数据流监控 Tab -->
                        <TabItem Header="📡 数据流监控">
                            <Border Background="White" CornerRadius="0,0,3,3" BorderBrush="#D5D8DC" BorderThickness="1,0,1,1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" 
                                            Background="#F8F9FA" 
                                            Padding="10,8"
                                            BorderBrush="#D5D8DC" 
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="📡 CAN总线数据流" FontWeight="SemiBold" Foreground="#2C3E50" FontSize="12"/>
                                                <TextBlock Text=" (ID: 0x7E8)" Foreground="#7F8C8D" FontSize="11" Margin="4,0,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <ProgressBar Width="200" Height="6" Value="0" Maximum="100"
                                                             Foreground="#3498DB" Background="#D5D8DC" BorderThickness="0"/>
                                                <TextBlock x:Name="ProgressText"
                                                           Text="0%" 
                                                           Foreground="#3498DB" 
                                                           FontSize="11" 
                                                           FontWeight="SemiBold" 
                                                           Margin="8,0,0,0"/>
                                            </StackPanel>

                                            <Border Grid.Column="2" Background="#FEF9E7" CornerRadius="10" Padding="10,4">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="CountdownText"
                                                               Text="⏱️ 等待中" 
                                                               FontSize="11" 
                                                               FontWeight="Bold" 
                                                               Foreground="#E67E22"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <DataGrid x:Name="DataStreamGrid"
                                                  AutoGenerateColumns="False" 
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal"
                                                  BorderThickness="0"
                                                  Background="White"
                                                  RowHeight="28"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  FontSize="12"
                                                  Margin="4">
                                            <DataGrid.Resources>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#F8F9FA"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Setter Property="BorderBrush" Value="#D5D8DC"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                                </Style>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="序号" Width="50" Binding="{Binding Index}"/>
                                                <DataGridTextColumn Header="数据ID" Width="90" Binding="{Binding Id}"/>
                                                <DataGridTextColumn Header="数值" Width="100" Binding="{Binding Value}"/>
                                                <DataGridTextColumn Header="单位" Width="60" Binding="{Binding Unit}"/>
                                                <DataGridTextColumn Header="时间戳" Width="120" Binding="{Binding Timestamp}"/>
                                                <DataGridTextColumn Header="状态" Width="70" Binding="{Binding Status}"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </TabItem>

                        <!-- ==================== DTC 故障码 Tab（最终稳定版） ==================== -->
                        <TabItem Header="🔧 DTC故障码">
                            <Border Background="White" CornerRadius="0,0,3,3" 
            BorderBrush="#D5D8DC" BorderThickness="1,0,1,1"
            Padding="8">
                                <DockPanel>
                                    <!-- 顶部汇总 -->
                                    <Border DockPanel.Dock="Top" Background="#F8F9FA" Padding="10,8"
                    BorderBrush="#D5D8DC" BorderThickness="0,0,0,1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔧 DTC故障码检测" FontWeight="Bold" FontSize="13" Foreground="#2C3E50"/>
                                            <TextBlock Text="{Binding DtcSummaryText}" Foreground="#E74C3C" FontSize="12" 
                               FontWeight="SemiBold" Margin="15,0,0,0"/>
                                            <ProgressBar Width="200" Height="6" Margin="20,0,0,0"
                                 IsIndeterminate="{Binding IsReadingDtc}">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsReadingDtc}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>
                                        </StackPanel>
                                    </Border>

                                    <!-- ECU 列表 -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding DtcResultList}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="4,4,4,8" Padding="10,8"
                                    BorderBrush="#D5D8DC" BorderThickness="1"
                                    CornerRadius="3" Background="White">
                                                        <StackPanel>
                                                            <!-- ECU 行：图标 + 名称 + 汇总字符串 + 错误信息 -->
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                                <!-- 成功/失败图标 -->
                                                                <TextBlock FontSize="14" Margin="0,0,6,0">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="✅"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Success}" Value="False">
                                                                                    <Setter Property="Text" Value="❌"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <!-- ECU 名称 -->
                                                                <TextBlock Text="{Binding EcuName}" FontWeight="Bold" FontSize="13" 
                                                   Foreground="#2C3E50" Width="80"/>
                                                                <!-- 直接用 DtcSummary 字符串，不拆分！ -->
                                                                <TextBlock Text="{Binding DtcSummary}" FontSize="12" 
                                                   Foreground="#333333" Margin="10,0,0,0"/>
                                                                <!-- 错误信息（失败时显示） -->
                                                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#E74C3C" 
                                                   FontSize="11" Margin="15,0,0,0">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Success}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <!-- 嵌套的 DTC 子列表（仅显示当前故障） -->
                                                            <ItemsControl ItemsSource="{Binding DtcList}" Margin="24,0,0,0">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <!-- 根 Grid：根据 IsActive 控制是否显示 -->
                                                                        <Grid Margin="0,2">
                                                                            <Grid.Style>
                                                                                <Style TargetType="Grid">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Grid.Style>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="80"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <!-- 故障码 -->
                                                                            <TextBlock Grid.Column="0" 
                                                                               Text="{Binding Code}"
                                                                               FontWeight="Bold" FontSize="12"
                                                                               Foreground="#E74C3C"
                                                                               FontFamily="Consolas"/>
                                                                            <!-- 状态标识 —— 可以完全删掉，或者改为固定显示“当前故障” -->
                                                                            <TextBlock Grid.Column="1" Margin="8,0,0,0" 
                                                                               Text="当前故障" 
                                                                               FontSize="11" FontWeight="SemiBold"
                                                                               Foreground="#E74C3C"/>       
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
